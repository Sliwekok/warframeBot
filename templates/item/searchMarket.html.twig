{% extends('layouts/app.html.twig') %}

{% block content %}

    {% if market|length > 0 %}
            <div class="col-10 offset-1 searchedItems">
                <div class="col-9">
                    <div class="col-12 itemRow">
                        <div class="col-4">
                            <span>Username</span>
                        </div>
                        <div class="status col-3">
                            <span>In-game status</span>
                        </div>
                        <div class="price col-2">
                            <span>Price</span>
                        </div>
                    </div>
                    {% for market_item in market %}
                        <div class="col-12 itemRow">
                            <div class="dmSellerInput col-9">
                                <input class="col-8" type="text" value="/w {{ market_item.user.ingameName }} Hi {{ market_item.user.ingameName }}! I want to buy [{{ item.name }}] for {{ market_item.platinum }} platinum. Is it still available?">
                            </div>
                            <div class="username col-4">
                                <span>{{ market_item.user.ingameName }}</span>
                            </div>
                            <div class="status col-3">
                                <span>{{ market_item.user.status }}</span>
                            </div>
                            <div class="price col-2">
                                <span>{{ market_item.platinum }}</span>
                            </div>
                            <div class="action col-3">
                                <button type="button" class="tooltipButton btn btn-outline-primary copyTextToClipboard" data-tooltip-placement="right" data-title="Copy to clipboard">Buy <i class="icon icon-tag"></i></button>
                            </div>

                        </div>
                    {% endfor %}
                </div>
                <div class="col-3" id="itemDescription">
                    <div class="col-12 title">{{ item.name }}</div>
                    <div class="col-12 picture">
                        <img src="{{ item.icon }}" alt="{{ item.name }}">
                    </div>
                    <div class="col-12 description">
                        {{ item.description }}
                    </div>
                </div>
            </div>

    {% else %}
        <div class="col-6 offset-3 text-center">
            <p><h2>Apparently there are no active offers of {{ item.name }}</h2></p>
        </div>
    {% endif %}

{% endblock %}
