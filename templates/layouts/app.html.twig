<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{ title ?? "Warframe bot" }}</title>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous" defer></script>
    <!-- Fonts -->
    <link rel="dns-prefetch" href="//fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css?family=Nunito" rel="stylesheet">

    <!-- Styles -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body>
    {{ include('layouts/alert.html.twig') }}
    <div id="container-fluid">
        <div class="row-fluid">
            {{ include('layouts/nav.html.twig') }}
        </div>

        <main class="row-fluid">
            <div class="main">
                <div class="row">

                    {% block content %}{% endblock %}

                </div>
            </div>
        </main>

        {% if app.user %}
            {{ include('item/followNew.html.twig') }}
        {% endif %}

        <datalist id="itemsList"></datalist>

    </div>
</body>

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

</html>
